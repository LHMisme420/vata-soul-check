# Secrets / keys
.env
**/*secret*
**/*private*
**/*key*
**/*keys*/**    # keep if you KNOW it's safe; remove this line if you intend to publish keys

# Node / Python / Rust
node_modules/
__pycache__/
*.pyc
target/

# Large / generated artifacts (keep if you want; remove lines you want tracked)
*.wtns
*.zkey
*.ptau
